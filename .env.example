# =============================================================================
# ArenaForge — environment variable reference
# =============================================================================
# Every variable the agent runtime reads is documented here. The
# `env-doc-parity` test in agent/__tests__/env-doc-parity.test.ts will FAIL
# if any production-referenced variable is missing from this file, so add
# new vars here when you reference them in production code.
#
# Lines starting with `#` are comments. Set values without `=` defaults
# (or override with your own) before running the agent.
# =============================================================================

# -----------------------------------------------------------------------------
# Chain selection (slice #11): exactly one MUST be set to "true". Boot fails
# fast otherwise — this prevents the silent "I thought I was on mainnet" bug.
# -----------------------------------------------------------------------------
USE_TESTNET=true
USE_LOCAL=false
USE_MONAD_MAINNET=false

# -----------------------------------------------------------------------------
# RPC endpoints. Used per the chain selection above.
# -----------------------------------------------------------------------------
MONAD_RPC_URL=https://rpc.monad.xyz
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz

# RPC tuning. Defaults are sensible; override only if you've measured that
# you need to.
# RPC_TIMEOUT_MS=30000
# RPC_RETRY_COUNT=3
# RPC_RETRY_DELAY_MS=1000

# -----------------------------------------------------------------------------
# Arena agent wallet. Funds tournament writes, ELO updates, prize transfers.
# -----------------------------------------------------------------------------
ARENA_AGENT_PRIVATE_KEY=0x...

# Optional: deployer wallet used by setup scripts. Falls back to
# ARENA_AGENT_PRIVATE_KEY when unset.
# DEPLOYER_PRIVATE_KEY=0x...

# -----------------------------------------------------------------------------
# Phase-1 core contract addresses (required at boot — agent fails fast).
# -----------------------------------------------------------------------------
ARENA_CORE_ADDRESS=0x...
ESCROW_ADDRESS=0x...
MATCH_REGISTRY_ADDRESS=0x...
ORACLE_DUEL_ADDRESS=0x...
STRATEGY_ARENA_ADDRESS=0x...
AUCTION_WARS_ADDRESS=0x...
QUIZ_BOWL_ADDRESS=0x...

# -----------------------------------------------------------------------------
# Phase-2 contract addresses (optional — features auto-disable when unset,
# but a *malformed* value still aborts boot to prevent silent feature loss).
# -----------------------------------------------------------------------------
# SEASONAL_RANKINGS_ADDRESS=0x...
# SPECTATOR_BETTING_ADDRESS=0x...

# -----------------------------------------------------------------------------
# Optional: existing ARENA token address. When set, the agent attaches to
# the existing token instead of launching a new one on boot.
# -----------------------------------------------------------------------------
# ARENA_TOKEN_ADDRESS=0x...

# -----------------------------------------------------------------------------
# Nad.fun integration (oracle duel + auction wars draw market data here).
# -----------------------------------------------------------------------------
NADFUN_API_URL=https://api.nadapp.net

# -----------------------------------------------------------------------------
# Moltbook integration. The agent posts match commentary, tournament
# announcements, and evolution reports to a public submolt feed.
# -----------------------------------------------------------------------------
MOLTBOOK_API_URL=https://www.moltbook.com
MOLTBOOK_AGENT_HANDLE=ArenaForge
MOLTBOOK_BEARER_TOKEN=
# Optional: override Moltbook's verification endpoint (defaults to upstream).
# MOLTBOOK_VERIFY_URL=
# Optional: name of the Moltbook submolt the agent posts into.
# SUBMOLT_NAME=ArenaForge

# -----------------------------------------------------------------------------
# Claude (Anthropic) extended-thinking integration. Optional; falls back to
# rule-based evolution / commentary when disabled.
# -----------------------------------------------------------------------------
CLAUDE_ENABLED=false
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_THINKING_BUDGET=10000
# CLAUDE_MAX_OUTPUT=4096
# CLAUDE_TIMEOUT_MS=25000
# CLAUDE_LOG_THINKING=false
# CLAUDE_LOG_TOKENS=true

# -----------------------------------------------------------------------------
# Autonomous scheduler (creates tournaments, discovers agents, posts
# milestones automatically).
# -----------------------------------------------------------------------------
AUTONOMOUS_ENABLED=true
# Tick interval in ms. Default 5 minutes. Min 60s.
AUTONOMOUS_INTERVAL_MS=300000
AUTO_CREATE_TOURNAMENTS=true
AUTO_TOKEN_UPDATES=true
AUTO_AGENT_DISCOVERY=true
# Auto-launch the ARENA token on first boot via nad.fun. Off by default.
AUTO_LAUNCH_TOKEN=false

# -----------------------------------------------------------------------------
# Bootstrap (slice #9): when "true", agent creates a hardcoded "Genesis"
# tournament on first boot if no tournaments exist on chain. Leave false
# for production deploys; ops should pre-seed tournaments.
# -----------------------------------------------------------------------------
BOOTSTRAP_SEED_TOURNAMENT=false

# -----------------------------------------------------------------------------
# Admin auth (slice #8). When unset, admin-gated mutations
# (createTournament, pauseTournament, resumeTournament) reject with
# "Unauthorized". Set this to enable the admin path; the value becomes the
# expected `Authorization: Bearer <token>` for those mutations.
# -----------------------------------------------------------------------------
# ARENA_ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# Logger config (slice #2).
#   LOG_LEVEL: debug | info | warn | error | silent (default: info; tests use silent)
#   LOG_FORMAT: json | pretty (default: pretty on TTY, json otherwise)
# -----------------------------------------------------------------------------
LOG_LEVEL=info
# LOG_FORMAT=json

# -----------------------------------------------------------------------------
# CORS origin allowlist (slice #8). Comma-separated. Wildcards are matched
# per single subdomain segment, e.g. https://*.vercel.app matches
# https://app.vercel.app but NOT https://evil.app.vercel.app.
# Localhost dev origins (5173, 5174, 3000) are always allowed.
# -----------------------------------------------------------------------------
# CORS_ORIGIN=https://*.vercel.app,https://app.example.com

# -----------------------------------------------------------------------------
# API server ports.
#   PORT: when set, GraphQL + Socket.IO share a single HTTP server on this
#         port (single-port mode for Render-style deploys).
#   GRAPHQL_PORT / WS_PORT: dual-port mode for local dev (defaults: 4000 and 3001).
# -----------------------------------------------------------------------------
# PORT=4000
# GRAPHQL_PORT=4000
# WS_PORT=3001

# -----------------------------------------------------------------------------
# Persistence.
# -----------------------------------------------------------------------------
# Override the SQLite database path. Default: ./arena-data.sqlite.
# ARENA_DB_PATH=./arena-data.sqlite

# -----------------------------------------------------------------------------
# Testnet faucet (slice #14). Used by:
#   - boot-time balance check (warns if balance < MIN_BALANCE_MON; tops up
#     automatically only when AUTO_FAUCET_TOPUP=true)
#   - `npm run faucet:topup [<addr>]` operator script (always claims)
# Faucets rate-limit per address (typically 1 claim per 12-24h).
# -----------------------------------------------------------------------------
# Endpoint URL for the Monad testnet faucet (HTTP POST {address}).
# MONAD_FAUCET_URL=https://faucet.monad.xyz/api/claim
# Below this many MON the agent logs a low-balance warning at boot.
# MIN_BALANCE_MON=0.5
# When "true", the agent calls the faucet at boot if balance is low.
# Off by default: faucets rate-limit, so we don't want unattended retry storms.
# AUTO_FAUCET_TOPUP=false

# -----------------------------------------------------------------------------
# Debug / development flags.
# -----------------------------------------------------------------------------
# Verbose event broadcaster log lines (slice #2).
# DEBUG_EVENTS=false

# Standard Node convention. Tests set this to "test" automatically.
# NODE_ENV=development
