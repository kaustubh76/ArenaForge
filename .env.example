# Network Configuration
MONAD_RPC_URL=https://rpc.monad.xyz
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
USE_TESTNET=true
USE_LOCAL=false

# Arena Agent Wallet
ARENA_AGENT_PRIVATE_KEY=0x...

# Contract Addresses (set after deployment)
ARENA_CORE_ADDRESS=0x...
ESCROW_ADDRESS=0x...
MATCH_REGISTRY_ADDRESS=0x...
ORACLE_DUEL_ADDRESS=0x...
STRATEGY_ARENA_ADDRESS=0x...
AUCTION_WARS_ADDRESS=0x...
QUIZ_BOWL_ADDRESS=0x...

# Phase 2 Contract Addresses
SEASONAL_RANKINGS_ADDRESS=0x...
SPECTATOR_BETTING_ADDRESS=0x...

# Nad.fun Integration
NADFUN_API_URL=https://api.nadapp.net

# Moltbook Integration
MOLTBOOK_API_URL=https://www.moltbook.com
MOLTBOOK_AGENT_HANDLE=ArenaForge
MOLTBOOK_BEARER_TOKEN=

# Claude API (Extended Thinking) - Optional
# Uncomment and configure if you have an Anthropic API key
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_ENABLED=false
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_THINKING_BUDGET=10000
# CLAUDE_MAX_OUTPUT=4096
# CLAUDE_TIMEOUT_MS=25000

# === Hardening (slices #2, #8, #9) ===
# Structured logger config (slice #2). LOG_LEVEL: debug | info | warn | error | silent.
# LOG_FORMAT: json | pretty. Pretty is auto when stdout is a TTY; json is the
# production default (one record per line, observability-friendly).
LOG_LEVEL=info
# LOG_FORMAT=json

# Admin bearer token for destructive GraphQL mutations (slice #8). When unset,
# admin-gated mutations (createTournament / pauseTournament / resumeTournament)
# fail with "Unauthorized". Setting this turns on admin auth.
# ARENA_ADMIN_TOKEN=

# When "true", the agent auto-creates a hardcoded Genesis tournament on first
# boot if no tournaments exist on chain (slice #9). Leave false for production.
BOOTSTRAP_SEED_TOURNAMENT=false

# Override the SQLite database path. Default: ./arena-data.sqlite. Useful for
# pointing at a backup or for tests.
# ARENA_DB_PATH=./arena-data.sqlite
